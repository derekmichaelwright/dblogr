# devtools::install_github("derekmichaelwright/agData")
library(agData) # Loads: tidyverse, ggpubr, ggbeeswarm, ggrepel
library(treemapify)
# devtools::install_github("derekmichaelwright/agData")
library(agData) # Loads: tidyverse, ggpubr, ggbeeswarm, ggrepel
library(treemapify)
gg_treemap <- function(area = "Canada", measurement = "Area harvested", year = 2018) {
#Prep data
xx <- agData_FAO_Crops %>%
filter(Area == area, Year == year, Measurement == measurement) %>%
arrange(desc(Value)) %>%
slice(1:25) %>%
mutate(Area = factor(Area, levels = unique(Area)))
# Plot
ggplot(xx, aes(area = Value, fill = Crop, label = Crop)) +
geom_treemap(color = "black") +
geom_treemap_text(place = "centre", grow = T, color = "white") +
scale_fill_manual(values = alpha(agData_Colors, 0.75)) +
theme_agData(legend.position = "none") +
labs(title = paste(area,"-",year,"-",measurement),
caption = "\xa9 www.dblogr.com/  |  Data: STATCAN")
}
areas <- c("World",
agData_FAO_Country_Table$Region,
agData_FAO_Country_Table$SubRegion,
agData_FAO_Country_Table$Country)
areas <- c("World",
agData_FAO_Country_Table$Region,
agData_FAO_Country_Table$SubRegion,
agData_FAO_Country_Table$Country)
pdf("country_treemaps.pdf")
for(i in areas) {
gg_treemap(area = i)
}
for(i in areas) {
gg_treemap(area = i)
}
dev.off()
dev.off()
areas <- c("World",
agData_FAO_Country_Table$Region,
agData_FAO_Country_Table$SubRegion,
agData_FAO_Country_Table$Country)
pdf("country_treemaps.pdf")
for(i in areas) {
print(gg_treemap(area = i))
}
dev.off()
areas <- c("World",
agData_FAO_Country_Table$Region,
agData_FAO_Country_Table$SubRegion,
agData_FAO_Country_Table$Country)
pdf("country_treemaps.pdf", width = 600, height = 400)
areas <- c("World",
agData_FAO_Country_Table$Region,
agData_FAO_Country_Table$SubRegion,
agData_FAO_Country_Table$Country)
pdf("country_treemaps.pdf", width = 600, height = 400)
for(i in areas) {
print(gg_treemap(area = i))
}
dev.off()
areas <- c("World",
agData_FAO_Country_Table$Region,
agData_FAO_Country_Table$SubRegion,
agData_FAO_Country_Table$Country)
pdf("country_treemaps.pdf", width = 600, height = 400)
for(i in areas) {
print(gg_treemap(area = i))
}
dev.off()
