scale_y_continuous(breaks = seq(0, 60, 10), limits = c(0, 60)) +
theme_agData() +
labs(title = "Adoption of No-Till Agriculture", x = NULL,
caption = "\xa9 www.dblogr.com/  |  Data: STATCAN")
