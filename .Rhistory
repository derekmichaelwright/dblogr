cypher_code <- function(x) {
c_number <- round(runif(1, 1, 999))
paste0(c_number, utf8ToInt(x) - utf8ToInt(cyphers[c_number]))
}
cypher_decode <- function(x) {
c_number <- as.numeric(substr(x, 1, 3))
utf8ToInt(x) + utf8ToInt(cyphers[c_number])
}
cypher_code("abcd")
c_number <- round(runif(1, 1, 999))
View(cypher_code)
