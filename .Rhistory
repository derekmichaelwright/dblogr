# devtools::install_github("derekmichaelwright/agData")
library(agData) # Loads: tidyverse, ggpubr, ggbeeswarm, ggrepel
# Prep data
pp <- agData_STATCAN_Population %>% filter(Year == max(Year)) %>%
select(area=Area, population=Value)
areas <- c("Canada", "Quebec", "Ontario", "British Columbia",
"Alberta", "Saskatchewan", "Manitoba", "Nova Scotia",
"Newfoundland and Labrador", "New Brunswick", "Prince Edward Island",
"Northwest Territories", "Yukon", "Nunavut", "Repatriated travellers")
dd <- read.csv("https://health-infobase.canada.ca/src/data/covidLive/covid19-download.csv") %>%
rename(area=prname) %>%
left_join(pp, by = "area") %>%
mutate(date = as.Date(date, format = "%Y-%m-%d"),
numdeathstoday = ifelse(numdeathstoday < 0, 0, numdeathstoday),
numtoday = ifelse(numtoday < 0, 0, numtoday),
deathspercapita = 1000000 * numdeaths / population,
casespercapita  = 1000000 * numtotal / population) %>%
arrange(area, date)
# Calculate moving average for daily cases
d1 <- dd %>% select(area, date, numtoday) %>% spread(area, numtoday)
for(i in 2:ncol(d1)) { d1[,i] <- round(movingAverage(d1[,i], n = 7), 1) }
d1 <- d1 %>% gather(area, numtoday_avg, 2:ncol(.))
# Calculate moving average for daily deaths
d2 <- dd %>% select(area, date, numdeathstoday) %>% spread(area, numdeathstoday)
for(i in 2:ncol(d2)) { d2[,i] <- round(movingAverage(d2[,i], n = 7), 1) }
d2 <- d2 %>% gather(area, numdeathstoday_avg, 2:ncol(.))
# Bind
dd <- dd %>%
left_join(d1, by = c("area","date")) %>%
left_join(d2, by = c("area","date")) %>%
mutate(area = factor(area, levels = areas),
deathstodaypercapita = 1000000 * numdeathstoday_avg / population,
casestodaypercapita  = 1000000 * numtoday_avg / population)
DT::datatable(dd)
# Prep data
dd <- read.csv("1310078301_databaseLoadingData.csv")
colnames(dd)[1] <- "DATE"
dd <- dd %>% mutate(DATE = as.Date(DATE))
xx <- dd %>%
group_by(DATE) %>%
summarise(VALUE = sum(VALUE, na.rm = T)) %>%
mutate(GEO = "Canada")
dd <- bind_rows(dd, xx) %>%
mutate(YEAR = as.factor(substr(DATE, 1, 4)),
Y2020 = ifelse(YEAR == "2020", "2020", "<2020"),
JulianDate = lubridate::yday(DATE),
GEO = gsub(", place of occurrence", "", GEO),
GEO = factor(GEO, levels = areas))
# Create plotting function
deathPlot <- function(areas) {
xx <- dd %>% filter(GEO %in% areas)
ggplot(xx, aes(x = JulianDate, y = VALUE, group = YEAR, color = Y2020, alpha = Y2020)) +
geom_line() +
facet_wrap(GEO ~ ., scales = "free_y", ncol = 5) +
scale_color_manual(name = NULL, values = c("darkgreen","darkred")) +
scale_alpha_manual(name = NULL, values = c(0.5,1)) +
theme_agData(legend.position = "bottom") +
labs(y = "Deaths per Week")
}
mp <- deathPlot(areas = areas)
ggsave("COVID_Canada_04_01.png", mp, width = 12, height = 8)
