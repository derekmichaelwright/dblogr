gather(Trait, Value, 2:3)
x2 <- read_xlsx("canada_ghg_data.xlsx", "Table5") %>%
gather(Trait, Value, 2)
xx <- bind_rows(x1, x2) %>%
mutate(Trait = factor(Trait, levels = unique(Trait)))
