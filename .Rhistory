setwd("C:/gitfolder")
library(devtools); library(roxygen2)
library(openxlsx); library(tidyverse)
library(rgeos); library(rworldmap)
##############################################################################
# Create Package
##############################################################################
#devtools::create("agData")
#dir.create("agData/Data")
#devtools::use_vognette()
##############################################################################
# Move R Scripts
##############################################################################
output <- "C:/gitfolder"
namesR <- list.files("R_agData")
file.copy(from = paste(output, "R_agData", namesR, sep = "/"),
to   = paste(output, "agData/R", namesR, sep = "/"),
overwrite = T)
# ^^^warnings is ok^^^
##############################################################################
agData_Colors <- c("darkgreen","darkgoldenrod2","darkred","darkblue",
"antiquewhite4", "darkorchid1",
"darkslategrey", "darkorange", "deeppink",
"aquamarine4",  "burlywood4", "darkseagreen4",
"deeppink3", "khaki4", "midnightblue",
"purple3","chocolate4", "darkolivegreen1",
"blue4","coral4", "tan4", "thistle4",
"aquamarine3", "burlywood3","darkseagreen3","darkgoldenrod3",
"purple4","chocolate3", "darkolivegreen2")
save(agData_Colors, file = "agData/Data/agData_Colors.RData")
##############################################################################
# Add FAO data sets
##############################################################################
aa <- read.xlsx("Datasets/FAO/FAO_Country_Tables.xlsx", "FAO_Region_Table") %>%
select(FAO_TABLE_NAME,
Region = UNSD_MACRO_REG,
SubRegion = UNSD_SUB_REG) %>%
mutate(Name = FAO_TABLE_NAME,
Region = factor(Region, levels = c("Americas", "Europe", "Africa", "Asia", "Oceania")),
SubRegion = factor(SubRegion, levels = SubRegion)) %>%
as.data.frame()
#
agData_FAO_Region_Table <- aa
#
save(agData_FAO_Region_Table, file = "agData/Data/agData_FAO_Region_Table.RData")
#
aa <- read.xlsx("Datasets/FAO/FAO_Country_Tables.xlsx", "FAO_Country_Table") %>%
select(Country = SHORT_NAME,
FAO_TABLE_NAME,
Region    = UNSD_MACRO_REG,
SubRegion = UNSD_SUB_REG,
DVDDVG    = UNSD_DVDDVG_REG,
ISO2 = ISO2_CODE,
ISO3 = ISO3_CODE) %>%
mutate(FAO_TABLE_NAME = as.character(FAO_TABLE_NAME),
FAO_TABLE_NAME = gsub("the ", "", FAO_TABLE_NAME),
FAO_TABLE_NAME = ifelse(FAO_TABLE_NAME == "Democratic Republic of Congo", "Democratic Republic of the Congo", FAO_TABLE_NAME)) %>%
#mutate(FAO_TABLE_NAME = ifelse(substr(FAO_TABLE_NAME, 1, 3) == "the", substr(FAO_TABLE_NAME, 5, nchar(FAO_TABLE_NAME)), FAO_TABLE_NAME)) %>%
filter(!is.na(Region), !Country %in% c("China mainland","China mainland and Taiwan"))
aa <- rbind(aa, c("Macedonia", "Republic of Macedonia", "Europe", "Southern Europe", "Developed"))
aa[aa$Country == "USSR", "DVDDVG"] <- "Developed"
sum(duplicated(aa$FAO_TABLE_NAME))
#
ww <- getMap(resolution = "low")
ll <- as.data.frame(gCentroid(ww, byid = T)) %>%
rownames_to_column() %>%
rename(Area = rowname, Lat = y, Lon = x) %>%
#mutate(FAO_TABLE_NAME = aa$FAO_TABLE_NAME[match(Area, aa$Name)]) %>%
#Area = ifelse(Area %in% aa$FAO_TABLE_NAME)plyr::mapvalues(Area, aa$Name, aa$FAO_TABLE_NAME, warn_missing = F)) %>%
bind_rows(read.xlsx("Datasets/FAO/FAO_Country_Tables.xlsx", "Old_Countries"))
#
sum(duplicated(ll$Area))
setdiff(ll$Area, aa$FAO_TABLE_NAME)
setdiff(aa$FAO_TABLE_NAME, ll$Area)
#
aa <- left_join(aa, ll, by = c("FAO_TABLE_NAME"="Area"))
#
aa[aa$Country == "Canada", c("Lat","Lon") ] <- c(52.137, -106.622)
aa[aa$Country == "USA", c("Lat", "Lon")]  <- c(39, -101.5)
aa[aa$Country == "China", c("Lat", "Lon")]  <- c(33.5, 102.1)
aa <- aa %>% arrange(Country)
#
unique(aa$Region)
unique(aa$SubRegion)
unique(aa$Country)
agData_FAO_Country_Table <- aa %>%
mutate(Region = factor(Region, levels = levels(agData_FAO_Region_Table$Region)),
SubRegion = factor(SubRegion, levels = levels(agData_FAO_Region_Table$SubRegion)),
Country = factor(Country, levels = unique(Country))) %>%
select(Country, FAO_TABLE_NAME, ISO2, ISO3, Lat, Lon, Region, SubRegion, DVDDVG) %>%
as.data.frame()
#
save(agData_FAO_Country_Table, file = "agData/Data/agData_FAO_Country_Table.RData")
#
