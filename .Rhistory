# Prep data
xx <- dd %>%
filter(!grepl("REGINA|SASKATOON|ATHABASCA|CUMBERLAND|PRINCE ALBERT", Constituency)) %>%
select(Constituency, BP, NDP, PC, SGP, LIB,SP, IND) %>%
gather(Party, Votes, BP, NDP, PC, SGP, LIB, SP, IND) %>%
mutate(Party = factor(Party, levels = parties))
# Plot
mp <- ggplot(xx, aes(x = Party, y = Votes, fill = Party)) +
geom_bar(stat = "identity", color = "black") +
facet_wrap(Constituency ~ ., scales = "free_y", ncol = 9) +
scale_fill_manual(values = cols) +
theme_agData(legend.position = "none") +
labs(title = "2020 Saskatchewan Election",
y = "Thousand Votes", x = NULL,
caption = "\xa9 www.dblogr.com/  |  Data: Elections SK")
ggsave("Sask_2020_Election_03.png", mp, width = 25, height = 8)
