# Create plotting function
deathPlot4 <- function(areas = "Canada") {
# Prep data
colors <- c(alpha(rep("darkred",3),0.7),"darkred")
xx <- d2 %>%
filter(Area %in% area, Year != 2021,
Sex == "Both sexes", Age != "all ages") %>%
group_by(Age, Year) %>%
summarise(Value = sum(Value, na.rm = T))
# Plot
ggplot(xx, aes(x = Year, y = Value / 1000, fill = as.factor(Year), group = Year)) +
geom_bar(stat = "identity", color = "black") +
facet_grid(. ~ Age) +
scale_fill_manual(name = NULL, values = colors) +
theme_agData(legend.position = "none") +
labs(title = area, y = "Thousand Deaths", x = NULL,
caption = "\xa9 www.dblogr.com/  |  Data: STATCAN")
}
mp <- deathPlot4(areas = "Canada")
