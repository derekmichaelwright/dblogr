# install.packages(c("tidyverse", "ggbeeswarm")
# install.packages(c("rgl", "plot3D")
library(tidyverse)  # Data wrangling %>%
library(ggbeeswarm) # geom_quasirandom()
library(ggpubr)     # ggarrange()
#
library(readxl)     # read.xlsx()
library(FactoMineR) # PCA() & HCPC()
library(plotly)     # plot_ly()
library(rgl)        # plot3d()
library(plot3D)     # scatter3D()
library(outliers)   # grubbs.test()
# Raw data from BELT
r1 <- read.csv("rawdata/LR68_SPGImageSummaryRev7.csv")
r2 <- read.csv("rawdata/LR68_SutherlandImageSummaryRev7.csv")
# Plot info
pp <- bind_rows(read_xlsx("rawdata/LR68_Data.xlsx", "2019 Sutherland Plots"),
read_xlsx("rawdata/LR68_Data.xlsx", "2019 SPG Plots")) %>%
select(Barcode=plot, Expt=expt, Rep=bloc, Id=name) %>%
mutate(Barcode = paste0("2019-", Barcode),
Id = ifelse(Id == "3339-3", "X3339.3", as.character(Id)),
Id = gsub(" ", "", Id),
Id = gsub("-", "\\.", Id))
# add Plot info & change factor levels
r1 <- r1 %>% left_join(pp, by = "Barcode") %>%
select(Barcode, Expt, Rep, Id, everything())
r2 <- r2 %>% left_join(pp, by = "Barcode") %>%
select(Barcode, Expt, Rep, Id, everything())
#
rr <- bind_rows(r1, r2) %>%
mutate(Rep = as.factor(Rep),
Type = ifelse(Id %in% c("X3339.3","IG72643"), Id, "LR68")) %>%
select(Barcode, Expt, Rep, Id, Type, AGILE.filepath, Image.Binary.Name,
Camera.Serial.Number, Processing.Date, everything()) %>%
rename(roundness=roundness..4.area..pi.major_axis.2.,
circularity=circularity..4.pi.Area..Perimeter.2..,
sphericity=sphericity..pi..1.3..volume..2.3....Surface.area.) %>%
gather(Trait, Value, 10:ncol(.)) %>%
filter(is.finite(Value))
#
dd <- rr %>%
group_by(Id, Trait, Expt) %>%
summarise(Value = mean(Value, na.rm = T)) %>%
ungroup()
#
str(dd %>% spread(Trait, Value))
r3 <- read_xlsx("rawdata/LR68_Data.xlsx", "2012 F2 data Abebe") %>%
select(Id=Name, Seed_Thickness=`Seed Thickness`, Seed_Width=`Seed Width`,
Seed_Mass1 = `Weight`) %>%
mutate(Id = gsub("LR-68", "LR68", Id),
Id = gsub("-", "\\.", Id))
r4 <- read_xlsx("rawdata/LR68_Data.xlsx", "2015 LR-68 Deposit Seed", skip = 1) %>%
select(Id=Subline, Cot, Background=background, Pattern=pattern) %>%
mutate(Id = gsub("LR-68", "LR68", Id),
Id = gsub("-", "\\.", Id),
Id = recode(Id, "3339.3"="X3339.3", "IG 72643"="IG72643"))
r5 <- read_xlsx("rawdata/LR68_Data.xlsx", "2016 LR-68 F9") %>%
select(Id=Subline, DTE=`Days to Emergence`, DTF=`Days to First Flower`, DTM,
Plant_Height=Height, Yield, SeedMass1000=`1000sdwt`,
Cot2=Cotyledon, Background2=`Seed coat`, Pattern2=`Seed pattern`) %>%
mutate(Id = gsub("-", "\\.", Id),
Id = recode(Id, "3339.3"="X3339.3", "IG 72643"="IG72643"))
r6 <- read_xlsx("rawdata/LR68_Data.xlsx", "2017 LR-68 INV") %>%
select(Id=Line, Plot_Mass=`total weight`,
Seed_Mass2=`seed weight`, Seed_Count=`seed count`) %>%
mutate(Id = gsub("-", "\\.", Id),
Id = recode(Id, "3339.3"="X3339.3", "IG 72643"="IG72643"))
#
mm <- r4 %>%
left_join(r3, by = "Id") %>%
left_join(r6, by = "Id") %>%
left_join(r5, by = "Id") %>%
filter(Id %in% unique(rr$Id)) %>%
mutate(Pattern = plyr::mapvalues(Pattern,
c("marble1","marble2","mottle"), c("marbled","marbled","absent")))
#
DT::datatable(select(mm, Id, Cot, Cot2, Background, Background2, Pattern, Pattern2))
gg_theme <- function(x, ...) {
theme(panel.background = element_rect(fill = "white"),
panel.grid = element_line(colour = "grey90"),
panel.border = element_rect(color = "black", fill = alpha("black",0)),
...)
}
#
rm(pp, r1, r2)
rm(r3, r4, r5, r6)
# ANOVA
xx <- rr %>% filter(Trait == "volume.mm.3.")
summary(aov(Value ~ Id, data = xx))
# conclusion: at least one genotype is different from the rest
# t.test
xx <- rr %>% filter(Trait == "volume.mm.3.", Id %in% c("IG72643","X3339.3"))
t.test(Value ~ Id, data = xx)
# conclusion: IG72643 & X3339.3 are different
ggplot(xx, aes(x = Id, y = Value, color = Id)) +
#geom_quasirandom() +
geom_beeswarm() +
gg_theme(legend.position = "none")
#
xx <- rr %>% filter(Trait == "volume.mm.3.", Id %in% c("LR68.129","LR68.219"))
t.test(Value ~ Id, data = xx)
# conclusion: LR68.129 & LR68.219 are not different
ggplot(xx, aes(x = Id, y = Value, color = Id)) +
#geom_quasirandom() +
geom_beeswarm() +
gg_theme(legend.position = "none")
xx <- dd %>%
filter(Trait %in% c("volume.mm.3.", "area.mm.2.")) %>%
spread(Trait, Value)
ggplot(xx, aes(x = area.mm.2., y = volume.mm.3., color = Id)) +
geom_quasirandom() +
gg_theme(legend.position = "none")
# Prep data for one genotype and trait
xx <- rr %>% filter(Id == "LR68.43", Trait == "area.mm.2.")
x<-xx;expt<-"2019 LR-68 Sutherland"; rep = 1
rep_Outliers <- function(x, expt, rep) {
xr <- x %>% filter(Expt == expt)#, Rep %in% rep)
qq <- (quantile(xr$Value, 0.75) - quantile(xr$Value, 0.25)) * 1.5
l1 <- mean(xr$Value) - qq
l2 <- mean(xr$Value) + qq
#
xr <- xr %>%
mutate(Outlier = F,
Outlier = ifelse(Value < l1 | Value > l2, T, Outlier)) %>%
filter(Outlier == T) %>% pull(AGILE.filepath)
xr
}
filter_Outliers <- function(x, type = "Expt") {
x2<-NA;x3<-x2;x5<-x2;x6<-x2
x1 <- rep_Outliers(x, "2019 LR-68 SPG", 1)
#x2 <- rep_Outliers(x, "2019 LR-68 SPG", 2)
#x3 <- rep_Outliers(x, "2019 LR-68 SPG", 3)
x4 <- rep_Outliers(x, "2019 LR-68 Sutherland", 1)
#x5 <- rep_Outliers(x, "2019 LR-68 Sutherland", 2)
#x6 <- rep_Outliers(x, "2019 LR-68 Sutherland", 3)
if(sum(colnames(x)=="Outlier")<1) { x <- x %>% mutate(Outlier = F) }
x <- x %>% mutate(Outlier = ifelse(AGILE.filepath %in% c(x1, x2, x3, x4, x5, x6), T, Outlier))
}
xx <- filter_Outliers(xx)
x2 <- xx %>%
mutate(Rep = ifelse(Expt == "2019 LR-68 SPG" & Rep == 1, 4, Rep),
Rep = ifelse(Expt == "2019 LR-68 SPG" & Rep == 2, 5, Rep),
Rep = ifelse(Expt == "2019 LR-68 SPG" & Rep == 3, 6, Rep))
# compare Expts
ggplot(xx, aes(x = Expt, y = Value)) +
stat_summary(fun.data = mean_sdl, fun.args = list(mult = 2),
geom="ribbon", alpha = 0.2, aes(group=1)) +
geom_boxplot(width = 0.2, coef = 3) +
geom_quasirandom(alpha = 0.3, aes(color = Outlier)) +
stat_summary(fun.y = mean, geom="line", lwd = 2, aes(group=1)) +
gg_theme(legend.position = "none")
#
ggplot(xx, aes(x = Rep, y = Value)) +
#stat_summary(fun.data = mean_sdl, fun.args = list(mult = 2),
#             geom="ribbon", alpha = 0.2, aes(group=1)) +
#geom_boxplot(width = 0.2, coef = 3) +
geom_quasirandom(alpha = 0.3, aes(color = Outlier)) +
#stat_summary(fun.y = mean, geom="line", lwd = 2, aes(group=1)) +
facet_grid(. ~ Expt) +
gg_theme(legend.position = "none")
xx <- rr %>% filter(Id == "LR68.43", Trait == "area.mm.2.")
# Test for Normality
# p < 0.05 = not a normal distribution
shapiro.test(xx %>% filter(Expt == "2019 LR-68 SPG") %>% pull(Value))
ggqqplot(xx %>% filter(Expt == "2019 LR-68 SPG") %>% pull(Value))
#
shapiro.test(xx %>% filter(Expt == "2019 LR-68 Sutherland") %>% pull(Value))
ggqqplot(xx %>% filter(Expt == "2019 LR-68 Sutherland") %>% pull(Value))
#
xx <- filter_Outliers(xx)
shapiro.test(xx %>% filter(Expt == "2019 LR-68 Sutherland", Outlier == F) %>% pull(Value))
ggqqplot(xx %>% filter(Expt == "2019 LR-68 Sutherland", Outlier == F) %>% pull(Value))
