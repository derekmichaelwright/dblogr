geom_bar(stat = "identity", color = "black", alpha = 0.8, size = 0.75) +
geom_errorbar(width = 0.25, size = 1,
aes(ymin = `Lower 95% confidence interval`,
ymax = `Upper 95% confidence interval`)) +
facet_grid(. ~ Sex) +
