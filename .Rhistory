labs(title = "Food Security - {round(frame_time)}",
y = "Tonnes Per Person", x = NULL,
caption = "\xa9 www.dblogr.com/  |  Data: FAOSTAT") +
# gganimate specific bits
transition_reveal(Year) +
ease_aes('linear')
mp
