xx <- bind_rows(read.xlsx("Datasets/USDA/AgTFPindividualcountries.xlsx", "Ag TFP",     cols = 1:70, startRow = 3) %>% mutate(Measurement = "Ag TFP"),
read.xlsx("Datasets/USDA/AgTFPindividualcountries.xlsx", "Inputs",     cols = 1:70, startRow = 3) %>% mutate(Measurement = "Inputs"),
read.xlsx("Datasets/USDA/AgTFPindividualcountries.xlsx", "Output",     cols = 1:70, startRow = 3) %>% mutate(Measurement = "Output"),
read.xlsx("Datasets/USDA/AgTFPindividualcountries.xlsx", "Ag Land",    cols = 1:70, startRow = 3) %>% mutate(Measurement = "Ag Land"),
read.xlsx("Datasets/USDA/AgTFPindividualcountries.xlsx", "Cropland",   cols = 1:70, startRow = 3) %>% mutate(Measurement = "Cropand"),
read.xlsx("Datasets/USDA/AgTFPindividualcountries.xlsx", "Irrig",      cols = 1:70, startRow = 3) %>% mutate(Measurement = "Irrig"),
read.xlsx("Datasets/USDA/AgTFPindividualcountries.xlsx", "Pasture",    cols = 1:70, startRow = 3) %>% mutate(Measurement = "Pasture"),
read.xlsx("Datasets/USDA/AgTFPindividualcountries.xlsx", "Labor",      cols = 1:70, startRow = 3) %>% mutate(Measurement = "Labor"),
read.xlsx("Datasets/USDA/AgTFPindividualcountries.xlsx", "Livestock",  cols = 1:70, startRow = 3) %>% mutate(Measurement = "Livestock"),
read.xlsx("Datasets/USDA/AgTFPindividualcountries.xlsx", "Machinery",  cols = 1:70, startRow = 3) %>% mutate(Measurement = "Machinery"),
read.xlsx("Datasets/USDA/AgTFPindividualcountries.xlsx", "Fertilizer", cols = 1:70, startRow = 3) %>% mutate(Measurement = "Fertilizer"),
read.xlsx("Datasets/USDA/AgTFPindividualcountries.xlsx", "Feed",       cols = 1:70, startRow = 3) %>% mutate(Measurement = "Feed")
) %>%
select(-Order, -FAO.N, -WDI.Code, -Region, -`Sub-Region`, -Inc.I, -Inc.II, -Note) %>%
select(Area=Country, Measurement, everything()) %>%
gather(Year, Value, 3:ncol(.), na.rm = T) %>%
filter(Value > 0) %>%
select(Area, Year, Measurement, Value) %>%
mutate(Area = ifelse(Area == "United States", "USA", Area),
Year = as.numeric(Year))
agData_USDA_TFP <- xx
