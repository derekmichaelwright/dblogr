library(agData) # Loads: tidyverse, ggpubr, ggbeeswarm, ggrepel
colnames(xx)[1] <- "date"
xx <- read.csv("https://data.cdc.gov/api/views/xkkf-xrst/rows.csv?accessType=DOWNLOAD&bom=true&format=true%20target=")
xx <- read.csv("https://data.cdc.gov/api/views/xkkf-xrst/rows.csv?accessType=DOWNLOAD&bom=true&format=true%20target=")
colnames(xx)[1] <- "date"
xx <- xx %>%
mutate(date = as.Date(date))
ggplot(xx, aes(x = date, y = , color = state)) +geom_line()
colnames(xx)[1] <- "Date"
xx <- xx %>%
mutate(Date = as.Date(Date))
ggplot(xx, aes(x = Date, y = , color = State)) + geom_line()
ggplot(xx, aes(x = Date, y = Observed.Number, color = State)) + geom_line()
ggplot(xx %>% filter(State == "United States"),
aes(x = Date, y = Observed.Number, color = State)) + geom_line()
View(xx)
ggplot(xx %>% filter(State == "United States"), aes(x = Date)) +
geom_line(aes(y = y = Observed.Number))
ggplot(xx %>% filter(State == "United States"), aes(x = Date)) +
geom_line(aes(y = Observed.Number))
ggplot(xx %>% filter(State == "United States"), aes(x = Date)) +
geom_line(aes(y = Observed.Number)) +
geom_line(aes(y = Average.Expected.Count))
