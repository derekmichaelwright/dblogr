# install.packages(c("tidyverse", "ggbeeswarm")
# install.packages(c("rgl", "plot3D")
library(tidyverse)  # Data wrangling %>%
library(ggbeeswarm) # geom_quasirandom()
library(ggpubr)     # ggarrange()
library(readxl)     # read.xlsx()
# install.packages(c("devtools", "yaml", "jsonlite", "data.table", "RcppEigen", "RSQLite", "qtl"))
# devtools::install_github("rqtl/qtl2")
library(qtl)
library(qtl2)
gg <- read.table("../GenoData/gt_LR68_D3_MAF5.txt", header = T) %>%
rename(chr=Chromosome, pos=Position) %>%
mutate(marker = paste(chr, pos, sep = "_"),
chr = as.integer(gsub("Lcu.2RBY.Chr", "", chr))) %>%
select(marker, chr, pos, everything()) %>%
filter(!is.na(chr))
#
x_geno <- t(gg %>% select(-chr, -pos) %>% column_to_rownames("marker")) %>%
as.data.frame() %>% rownames_to_column(var = "Id") %>%
mutate(Id = gsub("LR.68", "LR68", Id))
write.csv(x_geno, "input/LR68_Pheno/LR68_geno.csv", row.names = F, quote = F)
write.csv(x_geno, "input/LR68_BELT/LR68_geno.csv", row.names = F, quote = F)
#
x_gmap <- gg %>% select( marker,  chr,  pos) %>%
mutate(chr = as.numeric(gsub("Lcu.2RBY.Chr", "", chr)))
write.csv(x_gmap, "input/LR68_Pheno/LR68_gmap.csv", row.names = F, quote = F)
write.csv(x_gmap, "input/LR68_BELT/LR68_gmap.csv", row.names = F, quote = F)
xx <- read.csv("../PhenoData/rawdata_numeric_LR68.csv") %>%
mutate(Expt = paste(Location, Planting.Date..date.)) %>%
select(Id=Name, Expt, everything()) %>%
group_by(Id, Expt) %>%
summarise_at(vars(colnames(.)[8:ncol(.)]), funs(mean)) %>%
ungroup() %>%
gather(Trait, Value, 3:ncol(.)) %>%
mutate(Trait = paste(Trait, Expt, sep = "_"),
Trait = gsub(" ", ".", Trait)) %>%
select(-Expt) %>%
spread(Trait, Value) %>%
select_if(~!all(is.na(.))) %>%
mutate(Id = plyr::mapvalues(Id, c("3339-3","IG 72643"), c("X3339.3","IG72643")),
Id = gsub("LR-68", "LR68", Id),
Id = gsub("-", ".", Id))
xx <- xx %>% filter(Id %in% x_geno$Id)
write.csv(xx, "input/LR68_Pheno/LR68_pheno.csv", row.names = F)
p1 <- read_xlsx("../Fieldplans/Didier_List_Sutherland and SPG.xlsx", "LR-68 SPG") %>%
select(Plot=plot, Id=name) %>%
mutate(Plot = as.character(Plot))
b1 <- read.csv("../BELT/Lentil_RILs210331T172431.csv") %>%
select(-X) %>%
filter(metadata_directory_0 == "2019_LR68_SPG") %>%
mutate(Plot = substr(metadata_directory_1, 6, nchar(metadata_directory_1))) %>%
select(-file_path, -metadata_directory_0, -metadata_directory_1, -metadata_directory_2,
-metadata_directory_3, -processing_date, -serial_number) %>%
select(Plot, everything())
colnames(b1)[2:ncol(b1)] <- paste("LR68.SPG.2019", colnames(b1)[2:ncol(b1)], sep = "_")
b1 <- b1 %>% left_join(p1, by = "Plot") %>%
select(-Plot) %>%
group_by(Id) %>%
summarise_all(funs(mean), na.rm = T) %>%
ungroup() %>%
mutate(Id = plyr::mapvalues(Id, c("3339-3","IG 72643"), c("X3339.3","IG72643")),
Id = gsub("-", ".", Id))
#
p2 <- read_xlsx("../Fieldplans/Didier_List_Sutherland and SPG.xlsx", "LR-68 Sutherland") %>%
select(Plot=plot, Id=name) %>%
mutate(Plot = as.character(Plot))
b2 <- read.csv("../BELT/Lentil_RILs210331T172431.csv") %>%
select(-X) %>%
filter(metadata_directory_0 == "2019_LR68_Sutherland") %>%
mutate(Plot = substr(metadata_directory_1, 6, nchar(metadata_directory_1))) %>%
select(-file_path, -metadata_directory_0, -metadata_directory_1, -metadata_directory_2,
-metadata_directory_3, -processing_date, -serial_number) %>%
select(Plot, everything())
colnames(b2)[2:ncol(b2)] <- paste("LR68.SUT.2019", colnames(b2)[2:ncol(b2)], sep = "_")
b2 <- b2 %>% left_join(p2, by = "Plot") %>%
select(-Plot) %>%
group_by(Id) %>%
summarise_all(funs(mean), na.rm = T) %>%
ungroup() %>%
mutate(Id = plyr::mapvalues(Id, c("3339-3","IG 72643"), c("X3339.3","IG72643")),
Id = gsub("-", ".", Id))
#
bb <- full_join(b1, b2, by = "Id")
write.csv(bb, "input/LR68_BELT/LR68_pheno.csv", row.names = F, quote = F)
