#
# Prep data
find_hull <- function(df) df[chull(df[,"L.mean"], df[,"a.mean"]), ]
polys <- plyr::ddply(xx, "Cluster", find_hull) %>% mutate(Cluster = factor(Cluster))
colors <- c("darkorange2","darkgreen","darkblue","darkred","seagreen3","darkorange4")
traits <- c("a.mean", "b.mean", "L.mean",
"L.min", "L.max", "L.median", "L.standard.deviation",
"a.min", "a.max", "a.median", "a.standard.deviation",
"b.min", "b.max", "b.median", "b.standard.deviation",
"dark_cluster_percentage", "light_cluster_percentage",
"dark_cluster_L.", "dark_cluster_a.",
"dark_cluster_b.",  "light_cluster_L.",
"light_cluster_a.", "light_cluster_b.", "cluster_distance")
xx <- rr %>% filter(Trait %in% traits) %>%
spread(Trait, Value) %>%
group_by(Id) %>%
summarise_at(vars(traits), funs(mean)) %>%
column_to_rownames("Id") %>% as.matrix()
# PCA
mypca <- PCA(xx, ncp = 10, graph = F)
# Heirarcical clustering
mypcaH <- HCPC(mypca, nb.clust = 7, graph = F)
perc <- round(mypca[[1]][,2], 1)
x1.1 <- mypcaH[[1]] %>% rownames_to_column("Id")
x1.2 <- mypca[[3]]$coord %>% as.data.frame() %>% rownames_to_column("Id")
x1 <- left_join(x1.1, x1.2, by = "Id") %>%
left_join(mm, by = "Id") %>%
select(Id, Cluster=clust, Background, Pattern,
PC1=Dim.1, PC2=Dim.2, PC3=Dim.3, PC4=Dim.4, PC5=Dim.5,
PC6=Dim.6, PC7=Dim.7, PC8=Dim.8, PC9=Dim.9, PC10=Dim.10)
colors <- c("darkorange","darkgreen","darkblue","darkred")
xx <- dd %>%
filter(Expt == "2019 LR-68 Sutherland",
Trait %in% c("L.mean", "a.mean", "b.mean")) %>%
spread(Trait, Value) %>%
left_join(mm, by = "Id")
#
# Prep data
find_hull <- function(df) df[chull(df[,"L.mean"], df[,"a.mean"]), ]
polys <- plyr::ddply(xx, "Cluster", find_hull) %>% mutate(Cluster = factor(Cluster))
View(x1)
xx <- dd %>%
filter(Expt == "2019 LR-68 Sutherland",
Trait %in% c("L.mean", "a.mean", "b.mean")) %>%
spread(Trait, Value) %>%
left_join(mm, by = "Id") %>%
mutate(BP = paste(Background, Pattern))
polys <- plyr::ddply(xx, "BP", find_hull) %>% mutate(Cluster = factor(Cluster))
polys <- plyr::ddply(xx, "BP", find_hull)
polys <- plyr::ddply(xx, "BP", find_hull) %>% mutate(BP = factor(BP))
mp1.1 <- ggplot(xx) +
geom_polygon(data = polys, alpha = 0.6, aes(x = L.mean, y = a.mean, fill = BP)) +
geom_point(aes(x = L.mean, y = a.mean, colour = Background, pch = Pattern)) +
scale_color_manual(values = colors) +
scale_shape_manual(values = c(15,8,2,12)) +
gg_theme()
mp1.1
