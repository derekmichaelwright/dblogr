geom_bar(stat = "identity", color = "black") +
scale_fill_manual(values = c(alpha("darkred",0.5), "darkred")) +
scale_x_continuous(breaks = seq(1995, 2015, 10)) +
facet_wrap(Area ~ ., ncol = 5) +
theme_agData(legend.position = "none") +
