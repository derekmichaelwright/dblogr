##############################################################################
#x <- read.csv("Datasets/FAO/FAO_Crops.csv")
fixFAO <- function(x) {
years <- c(colnames(x)[grep("F",colnames(x))], colnames(x)[grep("N",colnames(x))])
x1 <- x %>% select(-years) %>%
select(-Area.Code, -Item.Code, -Element.Code) %>%
gather(key = "Year", value = "Value", 5:ncol(.)) %>%
mutate(Year = as.numeric(substr(Year, 2, 5))) %>%
#left_join(select(regions, Area = FAO_TABLE_NAME, Region, SubRegion, DVDDVG, Lat, Lon), by = "Area") %>%
#mutate(Area = plyr::mapvalues(Area, regions$FAO_TABLE_NAME, regions$Name, warn_missing = F)) %>%
filter(!is.na(Area), !is.na(Value)) %>%#
mutate(Area = factor(Area),
Area = plyr::mapvalues(Area,
c("United States of America", "United Kingdom of Great Britain and Northern Ireland"),
c("USA", "UK")))#,
#DVDDVG = factor(DVDDVG))
#SubRegion = ifelse(Area %in% a2$SubRegion, a2$SubRegion[match(Area, a2$SubRegion)], Region),
#Region = ifelse(Area %in% a2$SubRegion, a2$Region[match(Area, a2$SubRegion)], Region),
#Region = ifelse(Area %in% a3$Region, a3$Region[match(Area, a3$Region)], Region) )
x1
}
fixChina <- function(x) {
x1 <- x %>%
filter(Area != "China") %>%
mutate(Area = plyr::mapvalues(Area,
as.character(agData_FAO_Country_Table$FAO_TABLE_NAME),
as.character(agData_FAO_Country_Table$Country),
warn_missing = F) )
}
##############################################################################
agData_FAO_Crops <- read.csv("Datasets/FAO/Production_Crops_E_All_Data/Production_Crops_E_All_Data_NOFLAG.csv") %>% #read.csv("Datasets/FAO/FAO_Crops.csv") %>%
fixFAO() %>% fixChina() %>%
filter(Element != "Feed") %>%
mutate(Value = ifelse(Element == "Yield", Value / 10000, Value), # hg/ha -> t/ha
Element = factor(Element),
Unit = plyr::mapvalues(Unit, c("ha","hg/ha","tonnes"), c("hectares", "t/ha","tonnes")),
Item = plyr::mapvalues(Item, c("Rice, paddy"), c("Rice"))) %>%
rename(Crop = Item, Measurement = Element) %>%
arrange(Year) %>% filter(Value > 0) %>%
select(Area, Year, Crop, everything()) %>%
as.data.frame()
