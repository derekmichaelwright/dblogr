find_hull <- function(df) df[chull(df[,"L.mean"], df[,"a.mean"]), ]
polys <- plyr::ddply(x1, "Cluster", find_hull) %>% mutate(Cluster = factor(Cluster))
colors <- c("darkorange","darkgreen","darkblue","darkred")
xx <- dd %>%
filter(Expt == "2019 LR-68 Sutherland",
Trait %in% c("L.mean", "a.mean", "b.mean")) %>%
spread(Trait, Value) %>%
left_join(mm, by = "Id")
#
# Prep data
find_hull <- function(df) df[chull(df[,"L.mean"], df[,"a.mean"]), ]
polys <- plyr::ddply(x1, "Cluster", find_hull) %>% mutate(Cluster = factor(Cluster))
