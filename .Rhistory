mp <- plot_ly(xx, color = ~Pattern,
x = ~a.mean, y = ~b.mean, z = ~L.mean,
text = ~paste0("Cotyledon Color: ", Cot,
"\nBackground ", Background, "\n", Id),
colors = c("darkorange","darkgreen","darkblue","darkred")) %>%
add_markers() %>%
layout(scene = list(xaxis = list(title = "a"), yaxis = list(title = "b"),
zaxis = list(title = "L")), title = "Seed Coat Pattern")
htmlwidgets::saveWidget(as.widget(mp), "LR68_3D_Pattern.html")
mp
