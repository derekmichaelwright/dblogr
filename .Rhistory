x1.2 <- mypca[[3]]$coord %>% as.data.frame() %>% rownames_to_column("Id")
x1 <- left_join(x1.1, x1.2, by = "Id") %>%
left_join(mm, by = "Id") %>%
select(Id, Cluster=clust, Background, Pattern,
PC1=Dim.1, PC2=Dim.2, PC3=Dim.3, PC4=Dim.4, PC5=Dim.5,
PC6=Dim.6, PC7=Dim.7, PC8=Dim.8, PC9=Dim.9, PC10=Dim.10)
write.csv(x1, "data_pca_results.csv", row.names = F)
