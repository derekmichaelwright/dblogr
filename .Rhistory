mutate(Cot = plyr::mapvalues(Cot, c("r","y"), c("red","yellow")))
x1 %>% filter(Cot != Cot2) # 3
x1 %>% filter(Background != Background2) # 40
x1 %>% filter(Pattern != Pattern2) # 9
