save(agData_USDA_TFP, file="agData/Data/agData_USDA_TFP.RData")
##############################################################################
# Crops
##############################################################################
agData_USDA_Wheat <- read.xlsx("Datasets/USDA/USDA_Wheat.xlsx", "WheatYearbookTable01-Full",
startRow = 5, colNames = F) %>%
rename(Item = X1, Year = X2, Planted.Acreage = X3, Area.Harvested = X4, Production = X5, Yield = X6, WAFP = X7) %>%
slice(1:(grep("Hard red winter", Item)-1)) %>% select(-WAFP) %>%
mutate(Area = "USA", Item = "Wheat",
Year            = as.numeric(substr(Year, 1, 4)),
Production      = as.numeric(Production) * 1000 * 60 * 0.453592, # (60 lb/bu) (0.453592 kg/lb)
Yield           = round(as.numeric(Yield) * 60 * 0.453592 * 2.47105 / 1000, 3), # (60 lb/bu) (0.453592 kg/lb) (2.47105 ac/ha)
Area.Harvested  = as.numeric(Area.Harvested) * 0.404686 * 1000000, # (0.404686 ha/ac)
Planted.Acreage = as.numeric(plyr::mapvalues(Planted.Acreage, "--", NA)) * 0.404686 * 1000000) %>%
gather("Element", "Value", Planted.Acreage, Area.Harvested, Yield, Production, na.rm = T) %>%
mutate(Unit = plyr::mapvalues(Element, from = unique(Element), to = c("ha", "ha", "tonnes/ha", "tonnes"))) %>%
select(Area, Year, Item, Element, Unit, Value)
##############################################################################
agData_USDA_Maize <- read.xlsx("Datasets/USDA/USDA_Feed Grains.xlsx", "FGYearbookTable01-Full",
startRow = 3, colNames = F) %>%
rename(Item = X1, Year = X2, Planted.Acreage = X3, Area.Harvested = X4, Production = X5, Yield = X6, WAFP = X7, Loan.Rate = X8) %>%
slice(1:(grep("Sorghum", Item)-1)) %>% select(-WAFP, -Loan.Rate) %>%
mutate(Area = "USA", Item = "Maize",
Year            = as.numeric(substr(Year, 1, 4)),
Production      = as.numeric(Production) * 1000 * 56 * 0.453592, # (56 lb/bu) (0.453592 kg/lb)
Yield           = round(as.numeric(Yield) * 56 * 0.453592 * 2.47105 / 1000, 3), # (56 lb/bu) (0.453592 kg/lb) (2.47105 ac/ha)
Area.Harvested  = as.numeric(Area.Harvested) * 0.404686 * 1000000, # (0.404686 ha/ac)
Planted.Acreage = as.numeric(Planted.Acreage) * 0.404686 * 1000000) %>%
gather("Element", "Value", Planted.Acreage, Area.Harvested, Yield, Production, na.rm = T) %>%
mutate(Unit = plyr::mapvalues(Element, from = unique(Element), to = c("ha", "ha", "tonnes/ha", "tonnes"))) %>%
select(Area, Year, Item, Element, Unit, Value)
