##############################################################################
agData_USDA_Oats <- read.xlsx("Datasets/USDA/USDA_Feed Grains.xlsx", "FGYearbookTable01-Full",
startRow = 3, colNames = F) %>%
rename(Item = X1, Year = X2, Planted.Acreage = X3, Area.Harvested = X4, Production = X5, Yield = X6, WAFP = X7, Loan.Rate = X8) %>%
slice(grep("Oats", Item):nrow(.)) %>% select(-WAFP, -Loan.Rate) %>%
mutate(Area = "USA", Item = "Oats",
Year            = as.numeric(substr(Year, 1, 4)),
Production      = as.numeric(Production) * 1000 * 34 * 0.453592, # (34 lb/bu) (0.453592 kg/lb)
Yield           = round(as.numeric(Yield) * 34 * 0.453592 * 2.47105 / 1000, 3), # (34 lb/bu) (0.453592 kg/lb) (2.47105 ac/ha)
Area.Harvested  = as.numeric(Area.Harvested) * 0.404686 * 1000000, # (0.404686 ha/ac)
Planted.Acreage = as.numeric(Planted.Acreage) * 0.404686 * 1000000) %>%
gather("Element", "Value", Planted.Acreage, Area.Harvested, Yield, Production, na.rm = T) %>%
mutate(Unit = plyr::mapvalues(Element, from = unique(Element), to = c("ha", "ha", "tonnes/ha", "tonnes"))) %>%
select(Area, Year, Item, Element, Unit, Value)
##############################################################################
agData_USDA_Crops <- bind_rows(agData_USDA_Wheat, agData_USDA_Maize, agData_USDA_Sorgum, agData_USDA_Barley, agData_USDA_Oats) %>%
mutate(Area = factor(Area),
Item = factor(Item),
Element = factor(plyr::mapvalues(Element, c("Area.Harvested", "Planted.Acreage"), c("Area harvested", "Area seeded"))),
Unit = plyr::mapvalues(Unit, c("ha","tonnes/ha"), c("hectares", "t/ha")),
Unit = factor(Unit)) %>%
rename(Crop = Item, Measurement = Element) %>%
arrange(Year) %>%
as.data.frame()
sum(is.na(agData_USDA_Crops))
save(agData_USDA_Crops, file="agData/Data/agData_USDA_Crops.RData")
