mp <- ggplot(pp %>% filter(Trait %in% traits[1]),
aes(x = pos / 1000000, y = Value)) +
geom_line(color = "darkgreen") +
geom_hline(yintercept = 3, color = "red") +
facet_grid(. ~ chr, scales = "free_x") +
coord_cartesian(expand = 0) +
labs(y = "LOD", x = "Mbp")
ggsave("Fig_LR68_BELT_QTL_1.png", mp, width = 8, height = 4)
