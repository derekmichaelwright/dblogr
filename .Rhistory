mp1.1 <- ggplot(x1) +
geom_polygon(data = polys, alpha = 0.4, aes(x = PC1, y = PC2, fill = Cluster)) +
geom_point(aes(x = PC1, y = PC2, colour = Background, pch = Pattern)) +
scale_fill_manual(values = rep("grey",6), guide = F) +
scale_color_manual(values = colors) +
scale_shape_manual(values = c(15,8,2,12)) +
gg_theme() +
labs(x = paste0("PC1 (", perc[1], "%)"),
y = paste0("PC2 (", perc[2], "%)"))
