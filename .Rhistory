geom_bar(stat = "identity", fill = "darkred", color = "black", alpha = 0.8) +
facet_grid(Measurement ~ Age, scale = "free_y") +
labs(y = "x 1000",
caption = "\xa9 www.dblogr.com/  |  Data: FOIA")
