select_if(~!all(is.na(.))) %>%
mutate(Id = plyr::mapvalues(Id, c("3339-3","IG 72643"), c("X3339.3","IG72643")),
Id = gsub("LR-68", "LR68", Id),
Id = gsub("-", ".", Id))
xx <- xx %>% filter(Id %in% x_geno$Id)
write.csv(xx, "input/LR68_Pheno/LR68_pheno.csv", row.names = F)
p1 <- read_xlsx("../Fieldplans/Didier_List_Sutherland and SPG.xlsx", "LR-68 SPG") %>%
select(Plot=plot, Id=name) %>%
mutate(Plot = as.character(Plot))
b1 <- read.csv("../BELT/Lentil_RILs210331T172431.csv") %>%
select(-X) %>%
filter(metadata_directory_0 == "2019_LR68_SPG") %>%
mutate(Plot = substr(metadata_directory_1, 6, nchar(metadata_directory_1))) %>%
select(-file_path, -metadata_directory_0, -metadata_directory_1, -metadata_directory_2,
-metadata_directory_3, -processing_date, -serial_number) %>%
select(Plot, everything())
colnames(b1)[2:ncol(b1)] <- paste("LR68.SPG.2019", colnames(b1)[2:ncol(b1)], sep = "_")
b1 <- b1 %>% left_join(p1, by = "Plot") %>%
select(-Plot) %>%
group_by(Id) %>%
summarise_all(funs(mean), na.rm = T) %>%
ungroup() %>%
mutate(Id = plyr::mapvalues(Id, c("3339-3","IG 72643"), c("X3339.3","IG72643")),
Id = gsub("-", ".", Id))
#
p2 <- read_xlsx("../Fieldplans/Didier_List_Sutherland and SPG.xlsx", "LR-68 Sutherland") %>%
select(Plot=plot, Id=name) %>%
mutate(Plot = as.character(Plot))
b2 <- read.csv("../BELT/Lentil_RILs210331T172431.csv") %>%
select(-X) %>%
filter(metadata_directory_0 == "2019_LR68_Sutherland") %>%
mutate(Plot = substr(metadata_directory_1, 6, nchar(metadata_directory_1))) %>%
select(-file_path, -metadata_directory_0, -metadata_directory_1, -metadata_directory_2,
-metadata_directory_3, -processing_date, -serial_number) %>%
select(Plot, everything())
colnames(b2)[2:ncol(b2)] <- paste("LR68.SUT.2019", colnames(b2)[2:ncol(b2)], sep = "_")
b2 <- b2 %>% left_join(p2, by = "Plot") %>%
select(-Plot) %>%
group_by(Id) %>%
summarise_all(funs(mean), na.rm = T) %>%
ungroup() %>%
mutate(Id = plyr::mapvalues(Id, c("3339-3","IG 72643"), c("X3339.3","IG72643")),
Id = gsub("-", ".", Id))
#
bb <- full_join(b1, b2, by = "Id")
write.csv(bb, "input/LR68_BELT/LR68_pheno.csv", row.names = F, quote = F)
myQTL_2 <- read_cross2("input/LR68_Pheno/LR68.yaml", quiet = F)
summary(myQTL_2)
#map <- insert_pseudomarkers(myQTL$gmap, step = 100000000)
map <- insert_pseudomarkers(myQTL_2$gmap, step = 0)
pr <- calc_genoprob(myQTL_2, map)
out <- scan1(pr, myQTL_2$pheno)
traits <- colnames(xx)[2:ncol(xx)]
pp <- out %>% as.data.frame() %>% rownames_to_column(var = "marker") %>%
left_join(x_gmap, by = "marker") %>%
select(marker, chr, pos, everything()) %>%
gather(Trait, Value, 4:ncol(.)) %>%
mutate(Trait = factor(Trait, levels = traits))
pdf("LR68_Pheno_QTL_results.pdf", width = 12, height = 4)
for(i in traits) {
print(ggplot(pp %>% filter(Trait %in% i), aes(x = pos / 1000000, y = Value)) +
geom_line(color = "darkgreen") +
geom_hline(yintercept = 3, color = "red") +
facet_grid(.~chr, scales = "free_x") +
labs(title = i, y = "LOD", x = "Mbp")
)
}
dev.off()
#
mp <- ggplot(pp %>% filter(Trait %in% traits[1]),
aes(x = pos / 1000000, y = Value)) +
#geom_point(size = 0.1, color = "darkgreen") +
geom_line(color = "darkgreen") +
geom_hline(yintercept = 3, color = "red") +
facet_grid(. ~ chr, scales = "free_x") +
labs(y = "LOD", x = "Mbp")
ggsave("Fig_LR68_Pheno_QTL_1.png", mp, width = 8, height = 4)
