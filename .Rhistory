xx
# List Measurements
xx %>% distinct(Size)
# Prep data for an example plot
xx <- xx %>% filter(Area == "Saskatchewan", Year %in% c(1976, 2011))
# Plot
mp <- ggplot(xx, aes(x = Item, y = Value, group = Area)) +
geom_bar(stat = "identity") +
facet_grid(. ~ Year) +
theme_agData(rotx = T) +
labs(title = "Size of Farms in Saskatchewan",
y = "Number of Farms", x = NULL)
ggsave("Intro_agData_STATCAN_FarmLand_Size.png", mp, width = 6, height = 4)
# Get Data
xx <- agData_STATCAN_FarmLand_Size %>% as_tibble()
xx
# List Measurements
xx %>% distinct(Size)
# Prep data for an example plot
xx <- xx %>% filter(Area == "Saskatchewan", Year %in% c(1976, 2011))
# Plot
mp <- ggplot(xx, aes(x = Size, y = Value, group = Area)) +
geom_bar(stat = "identity") +
facet_grid(. ~ Year) +
theme_agData(rotx = T) +
labs(title = "Size of Farms in Saskatchewan",
y = "Number of Farms", x = NULL)
mp
