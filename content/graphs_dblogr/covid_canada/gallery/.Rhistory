library(agData) # Loads: tidyverse, ggpubr, ggbeeswarm, ggrepel
# Prep data
dd <- read.csv("https://data.cdc.gov/api/views/xkkf-xrst/rows.csv?accessType=DOWNLOAD&bom=true&format=true%20target=")
colnames(dd)[1] <- "Date"
dd <- dd %>%
mutate(Date = as.Date(Date),
Excess.Deaths = (Excess.Lower.Estimate + Excess.Higher.Estimate) / 2)
DT::datatable(dd)
# Prep data
x1 <- dd %>%
filter(State == "United States", Type == "Predicted (weighted)") %>%
select(Date, State, Value=Observed.Number, Trait=Outcome)
x2 <- dd %>%
filter(State == "United States") %>%
select(Date, State, Value=Average.Expected.Count) %>%
mutate(Trait = "Expected")
xx <- bind_rows(x1, x2)
# Plot
mp <- ggplot(xx, aes(x = Date, y = Value / 1000, color = Trait)) +
geom_line() +
facet_wrap(State ~ .) +
theme_agData(legend.position = "bottom") +
labs(title = "Observed vs Expected Deaths in the USA",
y = "Deaths (Thousand)", x = NULL,
caption = "\xa9 www.dblogr.com/  |  Data: cdc.gov/")
ggsave("COVID_USA_01.png", mp, width = 6, height = 4)
ggsave("../../../dblogr/content/graphs_dblogr/covid_usa/gallery/gallery/COVID_USA_01.png", mp, width = 6, height = 4)
ggsave("../../../dblogr/content/posts_dblogr/covid_usa/featured.png", mp, width = 6, height = 4)
# Prep data
x1 <- dd %>%
filter(State != "United States", Type == "Predicted (weighted)") %>%
select(Date, State, Value=Observed.Number, Trait=Outcome)
x2 <- dd %>%
filter(State != "United States") %>%
select(Date, State, Value=Average.Expected.Count) %>%
mutate(Trait = "Expected")
xx <- bind_rows(x1, x2)
# Plot
mp <- ggplot(xx, aes(x = Date, y = Value / 1000, color = Trait)) +
geom_line() +
facet_wrap(State ~ ., ncol = 9, scales = "free_y") +
theme_agData(legend.position = "bottom") +
labs(title = "Observed vs Expected Deaths in the USA",
y = "Deaths (Thousand)", x = NULL,
caption = "\xa9 www.dblogr.com/  |  Data: cdc.gov/")
ggsave("COVID_USA_02.png", mp, width = 20, height = 8)
ggsave("../../../dblogr/content/graphs_dblogr/covid_usa/gallery/gallery/COVID_USA_02.png", mp, width = 20, height = 8)
xx <- dd %>% filter(State == "United States")
mp <- ggplot(xx, aes(x = Date, y = Excess.Deaths, color = Outcome)) +
geom_line() +
theme_agData(legend.position = "bottom") +
labs(title = "Excess Deaths in the USA",
y = "Deaths (Thousand)", x = NULL,
caption = "\xa9 www.dblogr.com/  |  Data: cdc.gov/")
ggsave("COVID_USA_03.png", mp, width = 6, height = 4)
ggsave("../../../dblogr/content/graphs_dblogr/covid_usa/gallery/gallery/COVID_USA_03.png", mp, width = 6, height = 4)
xx <- dd %>% filter(State != "United States", Date > "2020-01-01")
mp <- ggplot(xx, aes(x = Date, y = Excess.Deaths, color = Outcome)) +
geom_line() +
facet_wrap(State ~ ., ncol = 9) +
theme_agData(legend.position = "bottom") +
labs(title = "Excess Deaths in the USA",
y = "Deaths (Thousand)", x = NULL,
caption = "\xa9 www.dblogr.com/  |  Data: cdc.gov/")
ggsave("COVID_USA_04.png", mp, width = 20, height = 8)
ggsave("../../../dblogr/content/graphs_dblogr/covid_usa/gallery/gallery/COVID_USA_04.png", mp, width = 20, height = 8)
library(readxl)
xx <- read_xls("pnas_0610941104_10941Table11.xls", range = "A2:AM27", col_names = F)[-2,] %>%
t() %>% as.data.frame()
colnames(xx) <- xx[1,]
xx<- xx %>% slice(-1) %>%
mutate(City = as.Date(as.numeric(City), origin = "1899-12-30")) %>%
gather(Area, Value, 2:ncol(.)) %>%
mutate(Value = as.numeric(Value)) %>%
rename(Date = City)
mp <- ggplot(xx, aes(x = Date, y = Value, color = Area)) +
geom_line() +
facet_wrap(Area ~ ., nrow = 3) +
theme_agData(legend.position = "none") +
labs(title = "1918 Pandemic Death Rate / 100,000", y = NULL, x = NULL,
caption = "\xa9 www.dblogr.com/  |  Data: Collins et al. 1930")
ggsave("COVID_USA_05.png", mp, width = 10, height = 4)
ggsave("../../../dblogr/content/graphs_dblogr/covid_usa/gallery/gallery/COVID_USA_05.png", mp, width = 10, height = 4)
xx <- xx %>% filter(Date < "1919-01-11")
xx %>%
group_by(Area) %>%
summarise(Sum = sum(Value, na.rm = T)) %>%
arrange(Sum)
xx <- xx %>% filter(Area %in% c("Philadelphia", "St. Louis"))
mp <- ggplot(xx, aes(x = Date, y = Value, lty = Area)) +
geom_line(size = 1.5) +
theme_agData(legend.position = "bottom") +
labs(title = "1918 Pandemic Death Rate / 100,000", y = NULL, x = NULL,
caption = "\xa9 www.dblogr.com/  |  Data: Collins et al. 1930")
ggsave("COVID_USA_06.png", mp, width = 6, height = 4)
ggsave("../../../dblogr/content/graphs_dblogr/covid_usa/gallery/gallery/COVID_USA_06.png", mp, width = 6, height = 4)
