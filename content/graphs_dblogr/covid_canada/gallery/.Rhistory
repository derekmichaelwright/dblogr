ggsave("../../../dblogr/content/graphs_dblogr/covid_canada/gallery/gallery/COVID_Canada_18.png", mp, width = 6, height = 4)
lastdate <- max(as.Date(dd$date))
pp <- agData_STATCAN_Population %>% filter(Year == 2019) %>%
select(area=Area, population=Value)
xx <- dd %>% filter(date == lastdate) %>%
select(area, numtotal, numdeaths, numtested) %>%
left_join(pp, by = "area") %>%
mutate(DeathPerCase = 100 * numdeaths / numtotal,
DeathPerPop  = 100 * numdeaths / population,
CasesPerPop  = 100 * numtotal / population) %>%
filter(!is.na(area)) %>%
gather(Trait, Value, DeathPerCase, DeathPerPop, CasesPerPop) %>%
mutate(Trait = plyr::mapvalues(Trait, c("DeathPerCase", "DeathPerPop", "CasesPerPop"),
c("Deaths / Cases", "Deaths / Population", "Cases / Population")))
mp <- ggplot(xx, aes(x = area, y = Value, fill = Trait)) +
geom_bar(stat = "identity", color = "black") +
facet_grid(Trait ~ ., scales = "free_y") +
scale_fill_manual(values = c("darkblue","darkgreen","darkred")) +
theme_agData(legend.position = "none", rotx = T) +
labs(title = "COVID-19 Death and Infection Rates", y = "Percentage (%)", x = NULL,
caption = "\xa9 www.dblogr.com/  |  Data: Government of Canada")
ggsave("COVID_Canada_19.png", mp, width = 6, height = 8)
ggsave("../../../dblogr/content/graphs_dblogr/covid_canada/gallery/gallery/COVID_Canada_19.png", mp, width = 6, height = 8)
xx <- dd %>% filter(date > "2020-09-01") %>%
group_by(area) %>% summarise(Deaths = sum(numdeathstoday))
knitr::kable(xx)
mp <- ggplot(xx, aes(x = area, y = Deaths, fill = area)) +
geom_bar(stat = "identity", color = "black") +
theme_agData(legend.position = "none", rotx = T)
ggsave("COVID_Canada_20.png", mp, width = 6, height = 4)
ggsave("../../../dblogr/content/graphs_dblogr/covid_canada/gallery/gallery/COVID_Canada_20.png", mp, width = 6, height = 4)
