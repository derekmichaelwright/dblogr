# Create Plotting Function
gg_COVID <- function(x, Area) {
x <- x %>%
filter(area == Area) %>%
select(area, date, Cases=numtoday_avg, Deaths=numdeathstoday_avg,
Cases_cum=numtotal, Deaths_cum=numdeaths) %>%
gather(Trait, Value, Cases, Deaths, Cases_cum, Deaths_cum) %>%
mutate(Element = plyr::mapvalues(Trait, c("Cases","Deaths","Cases_cum","Deaths_cum"),
c("Daily (7 day avg)", "Daily (7 day avg)", "Cummulative", "Cummulative")),
Trait = plyr::mapvalues(Trait, c("Cases_cum", "Deaths_cum"), c("Cases", "Deaths")))
# Plot
ggplot(x, aes(x = date, y = Value, color = Trait)) +
geom_line(size = 1) +
scale_color_manual(name = NULL, values = c("darkgreen","darkred")) +
facet_wrap(Element ~ ., scales = "free_y") +
scale_x_date(date_breaks = "1 month", date_labels = "%b") +
theme_agData(legend.position = "bottom") +
labs(title = paste(Area, "COVID-19 Data"),
y = NULL, x = NULL,
caption = "\xa9 www.dblogr.com/  |  Data: Government of Canada")
}
mp <- gg_COVID(x = dd, Area = "Canada")
ggsave("COVID_Canada_13.png", mp, width = 6, height = 4)
ggsave("../../../dblogr/content/graphs_dblogr/covid_canada/gallery/gallery/COVID_Canada_13.png", mp, width = 6, height = 4)
ggsave("../../../dblogr/content/posts_dblogr/covid_canada/featured.png", mp, width = 6, height = 4)
# Plot
mp <- gg_COVID(dd, "Ontario")
ggsave("COVID_Canada_14.png", mp, width = 6, height = 4)
ggsave("../../../dblogr/content/graphs_dblogr/covid_canada/gallery/gallery/COVID_Canada_14.png", mp, width = 6, height = 4)
